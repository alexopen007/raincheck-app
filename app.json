{
  "expo": {
    "name": "RainCheck",
    "slug": "raincheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "raincheck",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4169E1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.raincheck.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4169E1"
      },
      "package": "com.raincheck.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Umbrella needs camera access to scan QR codes at stations."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D9488",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "sdkVersion": "54.0.0"
  }
}